\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Shooting solutions of the Sakiadis problem obtained by considering (\ref  {power_law_ode_only}) as an IVP with various values of $f_p''(0; \alpha )=\kappa $ for $\alpha = 0.3$. The solution to the boundary value problem (\ref  {power_law_ode_general}) for $\kappa =\kappa _p$ is indicated with a dashed curve, and corresponds to a separatrix between shooting solutions with distinctive behaviors. Solutions above the separatrix orbit are shown in blue, and solutions below it are shown in green; the latter obtain a local maximum in $[0, L]$. For $\kappa $ above the true value of $\kappa _p$ the solutions (shown in blue) obtain no local maximum anywhere on $[0, \infty )$.\relax }}{9}{figure.caption.3}\protected@file@percent }
\newlabel{fig:shooting}{{3}{9}{Shooting solutions of the Sakiadis problem obtained by considering (\ref {power_law_ode_only}) as an IVP with various values of $f_p''(0; \alpha )=\kappa $ for $\alpha = 0.3$. The solution to the boundary value problem (\ref {power_law_ode_general}) for $\kappa =\kappa _p$ is indicated with a dashed curve, and corresponds to a separatrix between shooting solutions with distinctive behaviors. Solutions above the separatrix orbit are shown in blue, and solutions below it are shown in green; the latter obtain a local maximum in $[0, L]$. For $\kappa $ above the true value of $\kappa _p$ the solutions (shown in blue) obtain no local maximum anywhere on $[0, \infty )$.\relax }{figure.caption.3}{}}
\newlabel{power_law_sakiadis_new_asymptotic}{{3.3}{9}{Shear-Thinning Fluids ($\alpha < 1/2$)}{equation.3.3}{}}
